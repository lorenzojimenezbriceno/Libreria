{
  "version": "0.2.0",
  "configurations": [

    {
      "name": ".NET 9: Launch MVC",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "requireExactSource": false,
      "program": "${workspaceFolder}/src/AppStore/bin/Debug/net9.0/AppStore.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/AppStore",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5141"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/src/AppStore/Views"
      }
    }
  ]
}
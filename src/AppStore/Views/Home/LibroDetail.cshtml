@model AppStore.Models.DTO.LibroVm

@{
    ViewData["Title"] = "Detalle del " + Model.Titulo + ", " + Model.Autor;
     var url = "";
    if (!Model.Imagen!.StartsWith("http"))
    {
        url = $"~/uploads/{Model.Imagen}";
    }
    else
    {
        url = Model.Imagen;
    }
}

<div class="movie-detail w-80 m-auto">
    <div class="img-container">
        <img alt="Portada Libro" src="@url">
    </div>
    
    <div class="detail-container">
        <h3>@Model.Titulo</h3>
        <h4>@Model.Descripcion</h4>
        <h4>@Model.Precio</h4>
        <h4>@(Model.CreationDate?.ToString("dd/MM/yyyy"))</h4>
        <h4>@Model.CategoriasNames</h4>
        <h4>Autor: @Model.Autor</h4>
    </div>

    <div class="w-80 m-auto">
        <a href="/Home/Index" class="btn btn-default">Atrás</a>
    </div>
</div>